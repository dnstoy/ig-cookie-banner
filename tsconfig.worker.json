{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist/worker",
    "rootDir": ".",
    "composite": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/worker/**/*.ts", "src/types/**/*.ts", "src/config/**/*.ts"]
}
